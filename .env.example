# Copiá este archivo a .env.local y completá con los valores reales.
# .env.local está gitignoreado — nunca se commitea.
# Para producción: Vercel → Settings → Environment Variables (mismos nombres).

# Número de WhatsApp para recibir comprobantes (formato internacional, sin +)
WEDDING_WHATSAPP=549261XXXXXXX

# Datos bancarios que se muestran en la sección Entrada
WEDDING_BANK_ALIAS=tu.alias.aca
WEDDING_BANK_CBU=0000000000000000000000

# Lista de invitados con códigos. Se genera con: npm run generate-codes
# Si no está definida, se usan los datos de prueba de lib/guests.ts
GUESTS_JSON='[{"code":"a3f9","name":"Juan Pérez","partySize":1}]'
